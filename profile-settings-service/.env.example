# VersionAI Profile & Settings Service

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
PORT=8007

DATABASE_URL=sqlite+aiosqlite:///./profile_settings.db

JWT_SECRET_KEY=change-me-to-a-long-random-string

# Image storage (local | s3)
IMAGE_STORAGE_MODE=local
LOCAL_UPLOAD_DIR=./uploads
IMAGE_SERVE_BASE_URL=http://localhost:8007/static/uploads

# S3 (production)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# S3_BUCKET_NAME=versionai-profiles
# S3_ENDPOINT_URL=http://localhost:4566

# Sibling services
AUTH_SERVICE_URL=http://localhost:8006
BRAIN_SERVICE_URL=http://localhost:8002
VIDEO_AVATAR_SERVICE_URL=http://localhost:8004
VOICE_SERVICE_URL=http://localhost:8003
ORCHESTRATOR_SERVICE_URL=http://localhost:8005

CORS_ORIGINS=["*"]
