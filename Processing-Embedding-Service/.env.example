# --- Application ---
APP_NAME="VersionAI Processing & Embedding Service"
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8001

# --- AWS / S3 ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=versionai-ingestion
S3_ENDPOINT_URL=http://localhost:4566

# --- SQS ---
SQS_QUEUE_URL=http://localhost:4566/000000000000/versionai-processing
SQS_ENDPOINT_URL=http://localhost:4566
SQS_MAX_MESSAGES=5
SQS_WAIT_TIME_SECONDS=20
SQS_VISIBILITY_TIMEOUT=300

# --- Worker ---
WORKER_CONCURRENCY=3
WORKER_SHUTDOWN_TIMEOUT=30

# --- Text processing ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_TEXT_LENGTH=5000000

# --- Embeddings ---
# Option A: OpenAI (fast, requires API key)
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536

# Option B: sentence-transformers (local, no API key)
EMBEDDING_PROVIDER=sentence-transformers
ST_MODEL_NAME=all-MiniLM-L6-v2

# --- Vector store ---
VECTOR_STORE_PROVIDER=faiss
FAISS_INDEX_DIR=./vector_store
# For production:
# VECTOR_STORE_PROVIDER=pinecone
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_INDEX_NAME=versionai
# PINECONE_NAMESPACE=default

# --- State ---
STATE_DB_PATH=./state/processing.db

# --- Security ---
# API_KEY=
CORS_ORIGINS=["*"]
