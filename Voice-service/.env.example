# VersionAI Voice Service – Environment Variables

# --- Application ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- TTS Provider (openai | elevenlabs | mock) ---
TTS_PROVIDER=mock

# --- OpenAI TTS ---
# OPENAI_API_KEY=sk-your-key-here
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_DEFAULT_VOICE=alloy

# --- ElevenLabs TTS ---
# ELEVENLABS_API_KEY=your-elevenlabs-key
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_DEFAULT_VOICE_ID=your-cloned-voice-id

# --- Audio output ---
DEFAULT_AUDIO_FORMAT=mp3
MAX_TEXT_LENGTH=4096

# --- Voice profile storage (s3 | local) ---
VOICE_PROFILE_STORAGE=local
VOICE_PROFILES_DIR=./voice_profiles

# --- S3 (for voice profile storage) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=versionai-voices
S3_ENDPOINT_URL=http://localhost:4566
S3_VOICE_PROFILES_PREFIX=profiles

# --- Sibling services ---
# BRAIN_SERVICE_URL=http://localhost:8002

# --- Security ---
# API_KEY=your-secret-api-key
CORS_ORIGINS=["*"]
