PORT=8008
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./voice_training.db
JWT_SECRET_KEY=versionai-dev-secret-change-in-production

# ElevenLabs for voice cloning (get key at https://elevenlabs.io)
ELEVENLABS_API_KEY=
ELEVENLABS_API_URL=https://api.elevenlabs.io/v1

# OpenAI for Whisper + translation
OPENAI_API_KEY=

# Voice Service
VOICE_SERVICE_URL=http://localhost:8003

# Audio constraints
MIN_AUDIO_DURATION_SECONDS=30
MAX_AUDIO_FILE_SIZE=52428800

CORS_ORIGINS=["*"]
