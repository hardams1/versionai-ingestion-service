# VersionAI Ingestion Service – Environment Variables

# --- Application ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- Upload constraints ---
MAX_UPLOAD_SIZE_BYTES=524288000  # 500 MB

# --- AWS / S3 ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=versionai-ingestion
S3_ENDPOINT_URL=http://localhost:4566  # LocalStack
S3_PREFIX=uploads

# --- SQS ---
SQS_QUEUE_URL=http://localhost:4566/000000000000/versionai-processing
SQS_ENDPOINT_URL=http://localhost:4566  # LocalStack

# --- Security ---
# API_KEY=your-secret-api-key  # Uncomment to enable API key auth
CORS_ORIGINS=["*"]
