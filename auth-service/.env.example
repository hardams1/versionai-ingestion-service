# VersionAI Auth Service

# --- Application ---
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8006

# --- Database ---
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/versionai_auth
# SQLite (local dev — no Postgres needed):
DATABASE_URL=sqlite+aiosqlite:///./auth.db

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- CORS ---
CORS_ORIGINS=["*"]

# --- Sibling Services ---
BRAIN_SERVICE_URL=http://localhost:8002
