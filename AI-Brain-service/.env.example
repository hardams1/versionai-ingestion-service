# --- Application ---
APP_NAME="VersionAI AI Brain Service"
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8002

# --- LLM Provider ---
# Option A: OpenAI (default)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1024

# Option B: Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_TEMPERATURE=0.7
# ANTHROPIC_MAX_TOKENS=1024

# --- LLM Reliability ---
LLM_TIMEOUT_SECONDS=60.0
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0

# --- Vector Store (read-only — built by Processing Service) ---
VECTOR_STORE_PROVIDER=faiss
FAISS_INDEX_DIR=./vector_store
# For production:
# VECTOR_STORE_PROVIDER=pinecone
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_INDEX_NAME=versionai
# PINECONE_NAMESPACE=default

# --- Embedding (for query encoding — must match Processing Service) ---
# Option A: OpenAI
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Option B: sentence-transformers (local)
# EMBEDDING_PROVIDER=sentence-transformers
# ST_MODEL_NAME=all-MiniLM-L6-v2

# --- Retrieval ---
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.3

# --- Redis (conversation memory) ---
REDIS_URL=redis://localhost:6379/0
MEMORY_TTL_SECONDS=3600
MEMORY_MAX_TURNS=20

# --- Safety ---
SAFETY_MAX_RESPONSE_LENGTH=4096

# --- Sibling Services (for health checks & integration) ---
INGESTION_SERVICE_URL=http://localhost:8000
PROCESSING_SERVICE_URL=http://localhost:8001
AUTH_SERVICE_URL=http://localhost:8006

# --- Security ---
# API_KEY=
CORS_ORIGINS=["*"]
