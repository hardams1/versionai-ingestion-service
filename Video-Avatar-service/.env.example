# VersionAI Video Avatar Service – Environment Variables

# --- Application ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- Renderer Provider (synclabs | d_id | mock) ---
RENDERER_PROVIDER=mock

# --- Sync Labs ---
# SYNCLABS_API_KEY=your-synclabs-key
# SYNCLABS_API_URL=https://api.synclabs.so/v2
# SYNCLABS_MODEL=sync-1.7.1-beta

# --- D-ID ---
# D_ID_API_KEY=your-d-id-key
# D_ID_API_URL=https://api.d-id.com

# --- Video output ---
DEFAULT_VIDEO_FORMAT=mp4
DEFAULT_RESOLUTION=512x512
DEFAULT_FPS=25
MAX_AUDIO_DURATION_SECONDS=300
MAX_AUDIO_SIZE_BYTES=26214400

# --- Avatar profile storage (s3 | local) ---
AVATAR_PROFILE_STORAGE=local
AVATAR_PROFILES_DIR=./avatar_profiles
AVATAR_IMAGES_DIR=./avatar_images

# --- Image validation (photorealistic quality gates) ---
MIN_IMAGE_WIDTH=256
MIN_IMAGE_HEIGHT=256
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096
MIN_IMAGE_FILE_SIZE=5000
MAX_IMAGE_FILE_SIZE=20971520
MAX_ASPECT_RATIO=2.0

# --- S3 (for avatar profile / image storage) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=versionai-avatars
S3_ENDPOINT_URL=http://localhost:4566
S3_AVATAR_PROFILES_PREFIX=profiles
S3_AVATAR_IMAGES_PREFIX=images

# --- Sibling services ---
# VOICE_SERVICE_URL=http://localhost:8003
# INGESTION_SERVICE_URL=http://localhost:8000
INGESTION_S3_BUCKET=versionai-ingestion
INGESTION_S3_PREFIX=uploads

# --- Security ---
# API_KEY=your-secret-api-key
CORS_ORIGINS=["*"]
